<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <!-- Battery exempt banner -->
    <LinearLayout
        android:id="@+id/batteryBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#30363D"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="0dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap to allow Jarvis to run in background"
            android:textColor="#E6EDF3"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

        <Button
            android:id="@+id/btnBatteryExempt"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Allow"
            android:textColor="#0D1117"
            android:textSize="12sp"
            android:backgroundTint="#00D4FF"/>

    </LinearLayout>

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jarvis"
        android:textColor="#00D4FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/batteryBanner"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/connectionDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="○"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/titleText"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service app — interact via notification"
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/connectionErrorText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#F85149"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="140dp"
        android:layout_height="56dp"
        android:text="Start"
        android:textColor="#0D1117"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#00D4FF"
        app:layout_constraintTop_toBottomOf="@id/connectionErrorText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/btnSessions"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Sessions"
        android:textColor="#E6EDF3"
        android:textSize="14sp"
        android:backgroundTint="#21262D"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Settings"
        android:textColor="#E6EDF3"
        android:textSize="14sp"
        android:backgroundTint="#21262D"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toEndOf="@id/btnSessions"
        android:layout_marginStart="12dp"/>

    <Button
        android:id="@+id/btnMemos"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Memos"
        android:textColor="#E6EDF3"
        android:textSize="14sp"
        android:backgroundTint="#21262D"
        app:layout_constraintTop_toBottomOf="@id/btnSessions"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btnQuickPhrases"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Quick Phrases"
        android:textColor="#E6EDF3"
        android:textSize="14sp"
        android:backgroundTint="#21262D"
        app:layout_constraintTop_toBottomOf="@id/btnMemos"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>