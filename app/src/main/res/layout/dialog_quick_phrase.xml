<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Trigger phrase"
        android:textColorHint="#8B949E">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputPhrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6EDF3"
            android:fontFamily="monospace"
            android:inputType="text"/>

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="e.g. commute, meeting mode"
        android:textColor="#6E7681"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Commands (comma-separated)"
        android:textColorHint="#8B949E">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputCommands"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6EDF3"
            android:fontFamily="monospace"
            android:inputType="textMultiLine"
            android:minLines="2"/>

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="e.g. play spotify, navigate to work, read messages"
        android:textColor="#6E7681"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"/>

</LinearLayout>