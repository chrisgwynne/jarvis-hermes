<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#161B22"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/textPhrase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#00D4FF"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/textCommands"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Edit"
            android:textColor="#E6EDF3"
            android:textSize="12sp"
            android:backgroundTint="#30363D"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="Delete"
            android:textColor="#F85149"
            android:textSize="12sp"
            android:backgroundTint="#30363D"/>

    </LinearLayout>

</LinearLayout>