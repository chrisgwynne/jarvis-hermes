<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#161B22"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/sessionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Session title"
        android:textColor="#E6EDF3"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sessionTime"
        android:layout_marginEnd="12dp"/>

    <TextView
        android:id="@+id/sessionTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2m ago"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/sessionPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Preview text..."
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/sessionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sessionCount"
        android:layout_marginEnd="12dp"/>

    <TextView
        android:id="@+id/sessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4 messages"
        android:textColor="#00D4FF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>